<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RITCO - Announcements</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <style>
        * { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Poppins', sans-serif; }
        .sidebar { background: #111827; color: white; width: 260px; min-height: 100vh; position: fixed; left: 0; top: 0; overflow-y: auto; }
        .sidebar-item { padding: 12px 20px; border-radius: 8px; transition: background 0.2s; cursor: pointer; display: flex; align-items: center; gap: 12px; color: #9CA3AF; }
        .sidebar-item:hover { background: #1F2937; color: white; }
        .sidebar-item-active { background: #15803D; color: white; }
        .sidebar-item-active:hover { background: #166534; }
        .main-content { margin-left: 260px; padding: 24px; background: #F8FAFC; min-height: 100vh; }
        .card { background: white; border-radius: 10px; padding: 20px; border: 1px solid #E5E7EB; }
        .btn-primary { background: #15803D; color: white; padding: 8px 20px; border-radius: 8px; font-weight: 600; border: none; cursor: pointer; transition: background 0.2s; }
        .btn-primary:hover { background: #166534; }
        .btn-danger { background: #DC2626; color: white; padding: 8px 20px; border-radius: 8px; font-weight: 600; border: none; cursor: pointer; transition: background 0.2s; }
        .btn-danger:hover { background: #B91C1C; }
        .announcement-card { border-left: 4px solid #15803D; }
        .announcement-card.urgent { border-left-color: #DC2626; }
        .announcement-card.info { border-left-color: #2563EB; }
        .input-field { width: 100%; padding: 10px 14px; border: 1px solid #E5E7EB; border-radius: 8px; font-size: 14px; transition: border 0.2s; background: white; }
        .input-field:focus { outline: none; border-color: #15803D; box-shadow: 0 0 0 3px rgba(21, 128, 61, 0.1); }
    </style>
</head>
<body>
    <aside class="sidebar">
        <div class="p-6 border-b border-gray-800">
            <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-[#15803D] rounded-lg flex items-center justify-center"><i class="fas fa-bus text-white text-xl"></i></div>
                <span class="text-2xl font-bold text-white">RITCO</span>
            </div>
            <p class="text-sm text-gray-500 mt-1">Admin Panel</p>
        </div>
        <nav class="p-4 space-y-1">
            <a href="/admin" class="sidebar-item"><i class="fas fa-home"></i> Dashboard</a>
            <a href="/admin-bookings" class="sidebar-item"><i class="fas fa-ticket-alt"></i> Bookings</a>
            <a href="/admin-passengers" class="sidebar-item"><i class="fas fa-users"></i> Passengers</a>
            <a href="/admin-routes" class="sidebar-item"><i class="fas fa-route"></i> Routes</a>
            <a href="/admin-schedules" class="sidebar-item"><i class="fas fa-calendar"></i> Schedules</a>
            <a href="/admin-buses" class="sidebar-item"><i class="fas fa-bus"></i> Buses</a>
            <a href="/admin-drivers" class="sidebar-item"><i class="fas fa-user-tie"></i> Drivers</a>
            <a href="/admin-employees" class="sidebar-item"><i class="fas fa-users-cog"></i> Employees</a>
            <a href="/admin-payments" class="sidebar-item"><i class="fas fa-credit-card"></i> Payments</a>
            <a href="/admin-reports" class="sidebar-item"><i class="fas fa-chart-bar"></i> Reports</a>
            <a href="/admin-announcements" class="sidebar-item sidebar-item-active"><i class="fas fa-bullhorn"></i> Announcements</a>
            <a href="/admin-support" class="sidebar-item"><i class="fas fa-headset"></i> Support</a>
            <a href="/admin-settings" class="sidebar-item"><i class="fas fa-cog"></i> Settings</a>
            <a href="/logout" class="sidebar-item text-red-400 hover:text-red-300"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>
    </aside>

    <main class="main-content">
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-bold text-[#111827]">Announcements</h1>
                <p class="text-[#6B7280] text-sm">Create and manage company announcements</p>
            </div>
            <button class="btn-primary" onclick="showCreateForm()"><i class="fas fa-plus mr-2"></i> New Announcement</button>
        </div>

        <!-- Create Announcement Form -->
        <div id="createForm" class="card mb-6 hidden">
            <h3 class="font-bold text-[#111827] mb-4">Create New Announcement</h3>
            <form class="space-y-4">
                <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Title</label><input type="text" placeholder="Announcement title" class="input-field"/></div>
                <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Content</label><textarea rows="4" placeholder="Announcement details..." class="input-field"></textarea></div>
                <div class="grid md:grid-cols-2 gap-4">
                    <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Priority</label><select class="input-field"><option>Normal</option><option>Urgent</option><option>Information</option></select></div>
                    <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Expiry Date</label><input type="date" class="input-field"/></div>
                </div>
                <div class="flex gap-2">
                    <button type="submit" class="btn-primary"><i class="fas fa-paper-plane mr-2"></i> Publish</button>
                    <button type="button" class="btn-outline" onclick="hideCreateForm()">Cancel</button>
                </div>
            </form>
        </div>

        <!-- Announcements List -->
        <div class="space-y-4">
            <div class="announcement-card urgent card">
                <div class="flex items-start justify-between">
                    <div>
                        <span class="badge-green text-xs">Urgent</span>
                        <h3 class="font-bold text-[#111827] mt-1">Schedule Changes for December</h3>
                        <p class="text-[#6B7280] text-sm mt-1">Due to the holiday season, bus schedules will be adjusted from December 20-25. Please check the updated timings.</p>
                        <p class="text-xs text-[#6B7280] mt-2">Posted: Dec 10, 2024 | Expires: Dec 25, 2024</p>
                    </div>
                    <div class="flex gap-2">
                        <button class="text-[#15803D] text-sm"><i class="fas fa-edit"></i></button>
                        <button class="text-red-600 text-sm"><i class="fas fa-trash"></i></button>
                    </div>
                </div>
            </div>

            <div class="announcement-card info card">
                <div class="flex items-start justify-between">
                    <div>
                        <span class="badge-green text-xs bg-blue-100 text-blue-600">Information</span>
                        <h3 class="font-bold text-[#111827] mt-1">New Payment Methods Available</h3>
                        <p class="text-[#6B7280] text-sm mt-1">We now accept MoMo, Airtel Money, and Visa/Mastercard payments. Enjoy more flexibility when booking.</p>
                        <p class="text-xs text-[#6B7280] mt-2">Posted: Dec 8, 2024 | Expires: Permanent</p>
                    </div>
                    <div class="flex gap-2">
                        <button class="text-[#15803D] text-sm"><i class="fas fa-edit"></i></button>
                        <button class="text-red-600 text-sm"><i class="fas fa-trash"></i></button>
                    </div>
                </div>
            </div>

            <div class="announcement-card card">
                <div class="flex items-start justify-between">
                    <div>
                        <span class="badge-green text-xs">General</span>
                        <h3 class="font-bold text-[#111827] mt-1">Christmas Promo - 20% Off!</h3>
                        <p class="text-[#6B7280] text-sm mt-1">Enjoy 20% discount on all bookings made between Dec 20-25. Use code: XMAS2024</p>
                        <p class="text-xs text-[#6B7280] mt-2">Posted: Dec 5, 2024 | Expires: Dec 25, 2024</p>
                    </div>
                    <div class="flex gap-2">
                        <button class="text-[#15803D] text-sm"><i class="fas fa-edit"></i></button>
                        <button class="text-red-600 text-sm"><i class="fas fa-trash"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        function showCreateForm() {
            document.getElementById('createForm').classList.remove('hidden');
        }
        function hideCreateForm() {
            document.getElementById('createForm').classList.add('hidden');
        }
    </script>
</body>
</html>
