<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RITCO - Manage Drivers</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <style>
        * { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Poppins', sans-serif; }
        .sidebar { background: #111827; color: white; width: 260px; min-height: 100vh; position: fixed; left: 0; top: 0; overflow-y: auto; }
        .sidebar-item { padding: 12px 20px; border-radius: 8px; transition: background 0.2s; cursor: pointer; display: flex; align-items: center; gap: 12px; color: #9CA3AF; }
        .sidebar-item:hover { background: #1F2937; color: white; }
        .sidebar-item-active { background: #15803D; color: white; }
        .sidebar-item-active:hover { background: #166534; }
        .main-content { margin-left: 260px; padding: 24px; background: #F8FAFC; min-height: 100vh; }
        .card { background: white; border-radius: 10px; padding: 20px; border: 1px solid #E5E7EB; }
        .btn-primary { background: #15803D; color: white; padding: 8px 20px; border-radius: 8px; font-weight: 600; border: none; cursor: pointer; transition: background 0.2s; }
        .btn-primary:hover { background: #166534; }
        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; padding: 12px; background: #F9FAFB; font-weight: 600; color: #6B7280; font-size: 13px; border-bottom: 2px solid #E5E7EB; }
        td { padding: 12px; border-bottom: 1px solid #E5E7EB; }
        .status-chip { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 13px; font-weight: 500; }
        .status-active { background: #DCFCE7; color: #15803D; }
        .status-pending { background: #FEF3C7; color: #D97706; }
        .status-inactive { background: #FEE2E2; color: #DC2626; }
        .driver-avatar { width: 40px; height: 40px; border-radius: 50%; background: #15803D; color: white; display: flex; align-items: center; justify-content: center; font-weight: 600; }
    </style>
</head>
<body>
    <aside class="sidebar">
        <div class="p-6 border-b border-gray-800">
            <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-[#15803D] rounded-lg flex items-center justify-center"><i class="fas fa-bus text-white text-xl"></i></div>
                <span class="text-2xl font-bold text-white">RITCO</span>
            </div>
            <p class="text-sm text-gray-500 mt-1">Admin Panel</p>
        </div>
        <nav class="p-4 space-y-1">
            <a href="/admin" class="sidebar-item"><i class="fas fa-home"></i> Dashboard</a>
            <a href="/admin-bookings" class="sidebar-item"><i class="fas fa-ticket-alt"></i> Bookings</a>
            <a href="/admin-passengers" class="sidebar-item"><i class="fas fa-users"></i> Passengers</a>
            <a href="/admin-routes" class="sidebar-item"><i class="fas fa-route"></i> Routes</a>
            <a href="/admin-schedules" class="sidebar-item"><i class="fas fa-calendar"></i> Schedules</a>
            <a href="/admin-buses" class="sidebar-item"><i class="fas fa-bus"></i> Buses</a>
            <a href="/admin-drivers" class="sidebar-item sidebar-item-active"><i class="fas fa-user-tie"></i> Drivers</a>
            <a href="/admin-employees" class="sidebar-item"><i class="fas fa-users-cog"></i> Employees</a>
            <a href="/admin-payments" class="sidebar-item"><i class="fas fa-credit-card"></i> Payments</a>
            <a href="/admin-reports" class="sidebar-item"><i class="fas fa-chart-bar"></i> Reports</a>
            <a href="/admin-announcements" class="sidebar-item"><i class="fas fa-bullhorn"></i> Announcements</a>
            <a href="/admin-support" class="sidebar-item"><i class="fas fa-headset"></i> Support</a>
            <a href="/admin-settings" class="sidebar-item"><i class="fas fa-cog"></i> Settings</a>
            <a href="/logout" class="sidebar-item text-red-400 hover:text-red-300"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>
    </aside>

    <main class="main-content">
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-bold text-[#111827]">Manage Drivers</h1>
                <p class="text-[#6B7280] text-sm">Manage driver profiles and assignments</p>
            </div>
            <button class="btn-primary"><i class="fas fa-user-plus mr-2"></i> Add Driver</button>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-4 gap-4 mb-6">
            <div class="card"><div class="text-2xl font-bold text-[#15803D]">28</div><p class="text-sm text-[#6B7280]">Total Drivers</p></div>
            <div class="card"><div class="text-2xl font-bold text-[#15803D]">22</div><p class="text-sm text-[#6B7280]">Active Drivers</p></div>
            <div class="card"><div class="text-2xl font-bold text-[#15803D]">4</div><p class="text-sm text-[#6B7280]">On Leave</p></div>
            <div class="card"><div class="text-2xl font-bold text-[#15803D]">2</div><p class="text-sm text-[#6B7280]">Available</p></div>
        </div>

        <!-- Drivers Table -->
        <div class="card">
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Driver</th>
                            <th>License</th>
                            <th>Phone</th>
                            <th>Assigned Bus</th>
                            <th>Route</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><div class="flex items-center gap-3"><div class="driver-avatar">JK</div><span class="font-medium">John Kamana</span></div></td>
                            <td>DL-2024-001</td>
                            <td>+250 788 000 011</td>
                            <td>RITCO-001</td>
                            <td>Kigali → Musanze</td>
                            <td><span class="status-chip status-active">Active</span></td>
                            <td>
                                <button class="text-[#15803D] text-sm font-semibold mr-2"><i class="fas fa-edit"></i></button>
                                <button class="text-[#15803D] text-sm font-semibold mr-2"><i class="fas fa-eye"></i></button>
                                <button class="text-red-600 text-sm font-semibold"><i class="fas fa-trash"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td><div class="flex items-center gap-3"><div class="driver-avatar">PN</div><span class="font-medium">Peter Niyo</span></div></td>
                            <td>DL-2024-002</td>
                            <td>+250 788 000 012</td>
                            <td>RITCO-002</td>
                            <td>Kigali → Rubavu</td>
                            <td><span class="status-chip status-active">Active</span></td>
                            <td>
                                <button class="text-[#15803D] text-sm font-semibold mr-2"><i class="fas fa-edit"></i></button>
                                <button class="text-[#15803D] text-sm font-semibold mr-2"><i class="fas fa-eye"></i></button>
                                <button class="text-red-600 text-sm font-semibold"><i class="fas fa-trash"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td><div class="flex items-center gap-3"><div class="driver-avatar">AM</div><span class="font-medium">Alice Mutesi</span></div></td>
                            <td>DL-2024-003</td>
                            <td>+250 788 000 013</td>
                            <td>RITCO-003</td>
                            <td>Kigali → Huye</td>
                            <td><span class="status-chip status-inactive">Inactive</span></td>
                            <td>
                                <button class="text-[#15803D] text-sm font-semibold mr-2"><i class="fas fa-edit"></i></button>
                                <button class="text-[#15803D] text-sm font-semibold mr-2"><i class="fas fa-eye"></i></button>
                                <button class="text-red-600 text-sm font-semibold"><i class="fas fa-trash"></i></button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-200">
                <span class="text-sm text-[#6B7280]">Showing 1-3 of 28 drivers</span>
                <div class="flex space-x-2">
                    <button class="px-3 py-1 border border-gray-300 rounded-lg hover:bg-gray-50 text-sm">Previous</button>
                    <button class="px-3 py-1 bg-[#15803D] text-white rounded-lg text-sm">1</button>
                    <button class="px-3 py-1 border border-gray-300 rounded-lg hover:bg-gray-50 text-sm">2</button>
                    <button class="px-3 py-1 border border-gray-300 rounded-lg hover:bg-gray-50 text-sm">3</button>
                    <button class="px-3 py-1 border border-gray-300 rounded-lg hover:bg-gray-50 text-sm">Next</button>
                </div>
            </div>
        </div>
    </main>
</body>
</html>
