<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RITCO - Settings</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <style>
        * { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Poppins', sans-serif; }
        .sidebar { background: #111827; color: white; width: 260px; min-height: 100vh; position: fixed; left: 0; top: 0; overflow-y: auto; }
        .sidebar-item { padding: 12px 20px; border-radius: 8px; transition: background 0.2s; cursor: pointer; display: flex; align-items: center; gap: 12px; color: #9CA3AF; }
        .sidebar-item:hover { background: #1F2937; color: white; }
        .sidebar-item-active { background: #15803D; color: white; }
        .sidebar-item-active:hover { background: #166534; }
        .main-content { margin-left: 260px; padding: 24px; background: #F8FAFC; min-height: 100vh; }
        .card { background: white; border-radius: 10px; padding: 20px; border: 1px solid #E5E7EB; }
        .btn-primary { background: #15803D; color: white; padding: 8px 20px; border-radius: 8px; font-weight: 600; border: none; cursor: pointer; transition: background 0.2s; }
        .btn-primary:hover { background: #166534; }
        .btn-danger { background: #DC2626; color: white; padding: 8px 20px; border-radius: 8px; font-weight: 600; border: none; cursor: pointer; transition: background 0.2s; }
        .btn-danger:hover { background: #B91C1C; }
        .input-field { width: 100%; padding: 10px 14px; border: 1px solid #E5E7EB; border-radius: 8px; font-size: 14px; transition: border 0.2s; background: white; }
        .input-field:focus { outline: none; border-color: #15803D; box-shadow: 0 0 0 3px rgba(21, 128, 61, 0.1); }
        .setting-group { border-bottom: 1px solid #E5E7EB; padding-bottom: 16px; margin-bottom: 16px; }
        .setting-group:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    </style>
</head>
<body>
    <aside class="sidebar">
        <div class="p-6 border-b border-gray-800">
            <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-[#15803D] rounded-lg flex items-center justify-center"><i class="fas fa-bus text-white text-xl"></i></div>
                <span class="text-2xl font-bold text-white">RITCO</span>
            </div>
            <p class="text-sm text-gray-500 mt-1">Admin Panel</p>
        </div>
        <nav class="p-4 space-y-1">
            <a href="/admin" class="sidebar-item"><i class="fas fa-home"></i> Dashboard</a>
            <a href="/admin-bookings" class="sidebar-item"><i class="fas fa-ticket-alt"></i> Bookings</a>
            <a href="/admin-passengers" class="sidebar-item"><i class="fas fa-users"></i> Passengers</a>
            <a href="/admin-routes" class="sidebar-item"><i class="fas fa-route"></i> Routes</a>
            <a href="/admin-schedules" class="sidebar-item"><i class="fas fa-calendar"></i> Schedules</a>
            <a href="/admin-buses" class="sidebar-item"><i class="fas fa-bus"></i> Buses</a>
            <a href="/admin-drivers" class="sidebar-item"><i class="fas fa-user-tie"></i> Drivers</a>
            <a href="/admin-employees" class="sidebar-item"><i class="fas fa-users-cog"></i> Employees</a>
            <a href="/admin-payments" class="sidebar-item"><i class="fas fa-credit-card"></i> Payments</a>
            <a href="/admin-reports" class="sidebar-item"><i class="fas fa-chart-bar"></i> Reports</a>
            <a href="/admin-announcements" class="sidebar-item"><i class="fas fa-bullhorn"></i> Announcements</a>
            <a href="/admin-support" class="sidebar-item"><i class="fas fa-headset"></i> Support</a>
            <a href="/admin-settings" class="sidebar-item sidebar-item-active"><i class="fas fa-cog"></i> Settings</a>
            <a href="/logout" class="sidebar-item text-red-400 hover:text-red-300"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>
    </aside>

    <main class="main-content">
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-bold text-[#111827]">Settings</h1>
                <p class="text-[#6B7280] text-sm">Manage system settings and configurations</p>
            </div>
            <button class="btn-primary"><i class="fas fa-save mr-2"></i> Save All Settings</button>
        </div>

        <!-- Company Information -->
        <div class="card mb-6">
            <h3 class="font-bold text-[#111827] mb-4"><i class="fas fa-building text-[#15803D] mr-2"></i> Company Information</h3>
            <div class="grid md:grid-cols-2 gap-4">
                <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Company Name</label><input type="text" value="RITCO Bus Transport" class="input-field"/></div>
                <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Slogan</label><input type="text" value="Travel Across Rwanda Comfortably" class="input-field"/></div>
                <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Email</label><input type="email" value="info@ritco.rw" class="input-field"/></div>
                <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Phone</label><input type="tel" value="+250 789 117 044" class="input-field"/></div>
                <div class="md:col-span-2"><label class="block text-sm font-medium text-[#6B7280] mb-1">Address</label><input type="text" value="KN 5 Rd, Remera, Kigali, Rwanda" class="input-field"/></div>
            </div>
        </div>

        <!-- Ticket Pricing -->
        <div class="card mb-6">
            <h3 class="font-bold text-[#111827] mb-4"><i class="fas fa-tags text-[#15803D] mr-2"></i> Ticket Pricing</h3>
            <div class="grid md:grid-cols-3 gap-4">
                <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Base Price (per km)</label><input type="number" value="50" class="input-field"/></div>
                <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Service Fee</label><input type="number" value="500" class="input-field"/></div>
                <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Tax (%)</label><input type="number" value="18" class="input-field"/></div>
            </div>
        </div>

        <!-- Email & SMS Settings -->
        <div class="card mb-6">
            <h3 class="font-bold text-[#111827] mb-4"><i class="fas fa-envelope text-[#15803D] mr-2"></i> Email & SMS Settings</h3>
            <div class="grid md:grid-cols-2 gap-4">
                <div><label class="block text-sm font-medium text-[#6B7280] mb-1">SMTP Host</label><input type="text" value="smtp.gmail.com" class="input-field"/></div>
                <div><label class="block text-sm font-medium text-[#6B7280] mb-1">SMTP Port</label><input type="text" value="587" class="input-field"/></div>
                <div><label class="block text-sm font-medium text-[#6B7280] mb-1">SMTP Username</label><input type="text" value="notifications@ritco.rw" class="input-field"/></div>
                <div><label class="block text-sm font-medium text-[#6B7280] mb-1">SMTP Password</label><input type="password" value="••••••••" class="input-field"/></div>
            </div>
        </div>

        <!-- Backup -->
        <div class="card">
            <h3 class="font-bold text-[#111827] mb-4"><i class="fas fa-database text-[#15803D] mr-2"></i> Backup</h3>
            <div class="flex gap-4">
                <button class="btn-primary"><i class="fas fa-download mr-2"></i> Download Backup</button>
                <button class="btn-primary bg-[#1F2937] hover:bg-[#111827]"><i class="fas fa-upload mr-2"></i> Restore Backup</button>
            </div>
        </div>
    </main>
</body>
</html>
