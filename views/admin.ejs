<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RITCO - Admin Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <style>
        * { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Poppins', sans-serif; }
        .sidebar { background: #111827; color: white; width: 260px; min-height: 100vh; position: fixed; left: 0; top: 0; overflow-y: auto; }
        .sidebar-item { padding: 12px 20px; border-radius: 8px; transition: background 0.2s; cursor: pointer; display: flex; align-items: center; gap: 12px; color: #9CA3AF; text-decoration: none; }
        .sidebar-item:hover { background: #1F2937; color: white; }
        .sidebar-item-active { background: #15803D; color: white; }
        .sidebar-item-active:hover { background: #166534; }
        .main-content { margin-left: 260px; padding: 24px; background: #F8FAFC; min-height: 100vh; }
        .stat-card { background: white; border-radius: 10px; padding: 20px; border: 1px solid #E5E7EB; }
        .stat-number { font-size: 1.8rem; font-weight: 800; color: #15803D; }
        .card { background: white; border-radius: 10px; padding: 20px; border: 1px solid #E5E7EB; }
        .btn-primary { background: #15803D; color: white; padding: 8px 20px; border-radius: 8px; font-weight: 600; border: none; cursor: pointer; transition: background 0.2s; }
        .btn-primary:hover { background: #166534; }
        .status-chip { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 13px; font-weight: 500; }
        .status-active { background: #DCFCE7; color: #15803D; }
        .status-pending { background: #FEF3C7; color: #D97706; }
        .status-cancelled { background: #FEE2E2; color: #DC2626; }
        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; padding: 12px; background: #F9FAFB; font-weight: 600; color: #6B7280; font-size: 13px; border-bottom: 2px solid #E5E7EB; }
        td { padding: 12px; border-bottom: 1px solid #E5E7EB; }
        .badge-green { background: #DCFCE7; color: #15803D; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }
        .sidebar-item i { width: 20px; }
    </style>
</head>
<body>
    <aside class="sidebar">
        <div class="p-6 border-b border-gray-800">
            <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-[#15803D] rounded-lg flex items-center justify-center"><i class="fas fa-bus text-white text-xl"></i></div>
                <span class="text-2xl font-bold text-white">RITCO</span>
            </div>
            <p class="text-sm text-gray-500 mt-1">Admin Panel</p>
        </div>
        <nav class="p-4 space-y-1">
            <a href="/admin" class="sidebar-item sidebar-item-active"><i class="fas fa-home"></i> Dashboard</a>
            <a href="/admin-bookings" class="sidebar-item"><i class="fas fa-ticket-alt"></i> Bookings</a>
            <a href="/admin-passengers" class="sidebar-item"><i class="fas fa-users"></i> Passengers</a>
            <a href="/admin-routes" class="sidebar-item"><i class="fas fa-route"></i> Routes</a>
            <a href="/admin-schedules" class="sidebar-item"><i class="fas fa-calendar"></i> Schedules</a>
            <a href="/admin-buses" class="sidebar-item"><i class="fas fa-bus"></i> Buses</a>
            <a href="/admin-drivers" class="sidebar-item"><i class="fas fa-user-tie"></i> Drivers</a>
            <a href="/admin-employees" class="sidebar-item"><i class="fas fa-users-cog"></i> Employees</a>
            <a href="/admin-payments" class="sidebar-item"><i class="fas fa-credit-card"></i> Payments</a>
            <a href="/admin-reports" class="sidebar-item"><i class="fas fa-chart-bar"></i> Reports</a>
            <a href="/admin-announcements" class="sidebar-item"><i class="fas fa-bullhorn"></i> Announcements</a>
            <a href="/admin-support" class="sidebar-item"><i class="fas fa-headset"></i> Support</a>
            <a href="/admin-settings" class="sidebar-item"><i class="fas fa-cog"></i> Settings</a>
            <a href="/logout" class="sidebar-item text-red-400 hover:text-red-300"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>
    </aside>
    <main class="main-content">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold text-[#111827]">Dashboard</h1>
            <div class="flex items-center space-x-4">
                <span class="text-sm text-[#6B7280]">Welcome back, Admin</span>
                <div class="w-10 h-10 bg-[#15803D] rounded-full flex items-center justify-center text-white font-bold">A</div>
            </div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
            <div class="stat-card"><div class="stat-number">156</div><p class="text-[#6B7280] text-sm">Today's Bookings</p></div>
            <div class="stat-card"><div class="stat-number">2.4M</div><p class="text-[#6B7280] text-sm">Today's Revenue</p></div>
            <div class="stat-card"><div class="stat-number">45.8M</div><p class="text-[#6B7280] text-sm">Monthly Revenue</p></div>
            <div class="stat-card"><div class="stat-number">12.5K</div><p class="text-[#6B7280] text-sm">Total Users</p></div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
            <div class="card"><div class="flex items-center justify-between"><span class="text-[#6B7280] text-sm">Available Buses</span><span class="font-bold text-[#111827]">45</span></div></div>
            <div class="card"><div class="flex items-center justify-between"><span class="text-[#6B7280] text-sm">Buses on Trip</span><span class="font-bold text-[#111827]">32</span></div></div>
            <div class="card"><div class="flex items-center justify-between"><span class="text-[#6B7280] text-sm">Drivers Available</span><span class="font-bold text-[#111827]">28</span></div></div>
            <div class="card"><div class="flex items-center justify-between"><span class="text-[#6B7280] text-sm">Pending Payments</span><span class="font-bold text-[#F59E0B]">12</span></div></div>
        </div>
        <div class="card">
            <div class="flex items-center justify-between mb-4">
                <h3 class="font-bold text-[#111827]"><i class="fas fa-clock text-[#15803D] mr-2"></i> Recent Bookings</h3>
                <a href="/admin-bookings" class="btn-primary text-sm">View All</a>
            </div>
            <div class="table-responsive">
                <table>
                    <thead><tr><th>Booking ID</th><th>Passenger</th><th>Route</th><th>Date</th><th>Status</th><th>Action</th></tr></thead>
                    <tbody>
                        <tr><td>#BK-001</td><td>John Doe</td><td>Kigali → Musanze</td><td>2024-12-10</td><td><span class="status-chip status-active">Confirmed</span></td><td><a href="/admin-bookings" class="text-[#15803D] text-sm font-semibold">View</a></td></tr>
                        <tr><td>#BK-002</td><td>Jane Smith</td><td>Kigali → Rubavu</td><td>2024-12-11</td><td><span class="status-chip status-pending">Pending</span></td><td><a href="/admin-bookings" class="text-[#15803D] text-sm font-semibold">View</a></td></tr>
                        <tr><td>#BK-003</td><td>Peter Mwangi</td><td>Kigali → Huye</td><td>2024-12-09</td><td><span class="status-chip status-cancelled">Cancelled</span></td><td><a href="/admin-bookings" class="text-[#15803D] text-sm font-semibold">View</a></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6">
            <a href="/admin-buses" class="btn-primary py-3 text-center"><i class="fas fa-plus mr-2"></i> Add Bus</a>
            <a href="/admin-routes" class="btn-primary py-3 text-center bg-[#1F2937] hover:bg-[#111827]"><i class="fas fa-route mr-2"></i> Add Route</a>
            <a href="/admin-schedules" class="btn-primary py-3 text-center bg-[#1F2937] hover:bg-[#111827]"><i class="fas fa-calendar-plus mr-2"></i> Add Schedule</a>
            <a href="/admin-reports" class="btn-primary py-3 text-center bg-[#1F2937] hover:bg-[#111827]"><i class="fas fa-file-export mr-2"></i> Export Report</a>
        </div>
    </main>
</body>
</html>
