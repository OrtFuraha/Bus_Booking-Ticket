<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background: #f0f2f5; }
        .agency-card { background: white; border-radius: 15px; padding: 30px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/"><i class="fas fa-ticket-alt"></i> Online Booking</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/agency"><i class="fas fa-building"></i> Agency</a></li>
                </ul>
            </div>
        </div>
    </nav>
    
    <div class="container mt-5">
        <div class="agency-card">
            <h2 class="mb-4"><i class="fas fa-building"></i> Agency Dashboard</h2>
            
            <h4><i class="fas fa-plus-circle"></i> Register New Agency</h4>
            <form id="agencyForm" class="mb-4">
                <div class="row">
                    <div class="col-md-3 mb-2">
                        <input type="text" class="form-control" id="agencyName" placeholder="Agency Name" required>
                    </div>
                    <div class="col-md-3 mb-2">
                        <input type="email" class="form-control" id="agencyEmail" placeholder="Email" required>
                    </div>
                    <div class="col-md-2 mb-2">
                        <input type="text" class="form-control" id="agencyPhone" placeholder="Phone">
                    </div>
                    <div class="col-md-2 mb-2">
                        <input type="text" class="form-control" id="agencyAddress" placeholder="Address">
                    </div>
                    <div class="col-md-2 mb-2">
                        <button type="submit" class="btn btn-success w-100"><i class="fas fa-plus"></i> Add</button>
                    </div>
                </div>
            </form>
            
            <h4><i class="fas fa-list"></i> Registered Agencies</h4>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Address</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody id="agenciesTable">
                        <tr><td colspan="6" class="text-center">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <script>
        async function loadAgencies() {
            try {
                const response = await fetch('/api/agencies');
                const agencies = await response.json();
                const tbody = document.getElementById('agenciesTable');
                
                if (agencies.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="6" class="text-center">No agencies registered</td></tr>';
                    return;
                }
                
                tbody.innerHTML = agencies.map(a => `
                    <tr>
                        <td>${a.id}</td>
                        <td>${a.name}</td>
                        <td>${a.email}</td>
                        <td>${a.phone || 'N/A'}</td>
                        <td>${a.address || 'N/A'}</td>
                        <td>${new Date(a.created_at).toLocaleDateString()}</td>
                    </tr>
                `).join('');
            } catch (error) {
                console.error('Error loading agencies:', error);
            }
        }
        
        document.getElementById('agencyForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const data = {
                name: document.getElementById('agencyName').value,
                email: document.getElementById('agencyEmail').value,
                phone: document.getElementById('agencyPhone').value,
                address: document.getElementById('agencyAddress').value
            };
            
            try {
                const response = await fetch('/api/agencies', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                if (response.ok) {
                    document.getElementById('agencyForm').reset();
                    loadAgencies();
                }
            } catch (error) {
                console.error('Error adding agency:', error);
            }
        });
        
        loadAgencies();
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
