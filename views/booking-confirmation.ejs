<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RITCO - Booking Confirmed</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <style>
        * { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Poppins', sans-serif; }
        .btn-primary { background: #15803D; color: white; padding: 10px 24px; border-radius: 10px; font-weight: 600; border: none; cursor: pointer; transition: background 0.2s; }
        .btn-primary:hover { background: #166534; }
        .btn-outline { background: transparent; color: #15803D; padding: 10px 24px; border-radius: 10px; font-weight: 600; border: 2px solid #15803D; cursor: pointer; transition: all 0.2s; }
        .btn-outline:hover { background: #15803D; color: white; }
        .card { background: white; border-radius: 10px; padding: 24px; border: 1px solid #E5E7EB; }
        .confirmation-icon { font-size: 64px; color: #15803D; }
        .nav-link { color: #1F2937; font-weight: 500; padding: 8px 16px; border-radius: 8px; transition: background 0.2s; }
        .nav-link:hover { background: #F3F4F6; }
        .qr-placeholder { width: 120px; height: 120px; background: #F3F4F6; border-radius: 10px; display: flex; align-items: center; justify-content: center; border: 2px dashed #D1D5DB; }
    </style>
</head>
<body>
    <div class="min-h-screen bg-[#F8FAFC]">
        <!-- Top Nav -->
        <nav class="bg-white border-b border-gray-200">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between items-center h-16">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-[#15803D] rounded-lg flex items-center justify-center"><i class="fas fa-bus text-white text-xl"></i></div>
                        <span class="text-2xl font-bold text-[#111827]">RITCO</span>
                    </div>
                    <div class="flex items-center space-x-4">
                        <span class="text-sm text-[#6B7280]"><i class="fas fa-user text-[#15803D] mr-1"></i> John Doe</span>
                    </div>
                </div>
            </div>
        </nav>

        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="text-center mb-8">
                <div class="confirmation-icon mb-4"><i class="fas fa-check-circle"></i></div>
                <h1 class="text-3xl font-bold text-[#111827]">Booking Confirmed!</h1>
                <p class="text-[#6B7280] mt-2">Your ticket has been booked successfully</p>
            </div>

            <div class="card">
                <!-- Booking Reference -->
                <div class="text-center border-b border-gray-200 pb-4 mb-4">
                    <p class="text-sm text-[#6B7280]">Booking Reference</p>
                    <p class="text-2xl font-bold text-[#111827]">#BK-2024-001</p>
                </div>

                <div class="grid md:grid-cols-2 gap-6">
                    <!-- Trip Details -->
                    <div>
                        <h3 class="font-bold text-[#111827] mb-3">Trip Details</h3>
                        <div class="space-y-2 text-sm">
                            <div class="flex justify-between"><span class="text-[#6B7280]">Route</span><span class="font-medium">Kigali → Musanze</span></div>
                            <div class="flex justify-between"><span class="text-[#6B7280]">Date</span><span class="font-medium">Dec 10, 2024</span></div>
                            <div class="flex justify-between"><span class="text-[#6B7280]">Departure</span><span class="font-medium">8:30 AM</span></div>
                            <div class="flex justify-between"><span class="text-[#6B7280]">Arrival</span><span class="font-medium">11:00 AM</span></div>
                            <div class="flex justify-between"><span class="text-[#6B7280]">Bus</span><span class="font-medium">Volcano Express</span></div>
                        </div>
                    </div>

                    <!-- Passenger Details -->
                    <div>
                        <h3 class="font-bold text-[#111827] mb-3">Passenger Details</h3>
                        <div class="space-y-2 text-sm">
                            <div class="flex justify-between"><span class="text-[#6B7280]">Name</span><span class="font-medium">John Doe</span></div>
                            <div class="flex justify-between"><span class="text-[#6B7280]">Seats</span><span class="font-medium">2 (10, 11)</span></div>
                            <div class="flex justify-between"><span class="text-[#6B7280]">Phone</span><span class="font-medium">+250 788 000 000</span></div>
                            <div class="flex justify-between"><span class="text-[#6B7280]">Email</span><span class="font-medium">john@email.com</span></div>
                            <div class="flex justify-between"><span class="text-[#6B7280]">Payment Status</span><span class="font-medium text-[#15803D]">Paid</span></div>
                        </div>
                    </div>
                </div>

                <!-- QR Code -->
                <div class="flex items-center justify-between mt-6 pt-6 border-t border-gray-200">
                    <div>
                        <p class="text-sm text-[#6B7280]">Scan to verify ticket</p>
                        <div class="qr-placeholder mt-2">
                            <i class="fas fa-qrcode text-4xl text-[#6B7280]"></i>
                        </div>
                    </div>
                    <div class="text-right">
                        <p class="text-2xl font-bold text-[#15803D]">6,500 RWF</p>
                        <p class="text-sm text-[#6B7280]">Total Paid</p>
                    </div>
                </div>

                <!-- Actions -->
                <div class="flex flex-wrap gap-3 mt-6 pt-6 border-t border-gray-200">
                    <button class="btn-primary"><i class="fas fa-download mr-2"></i> Download Ticket</button>
                    <button class="btn-outline"><i class="fas fa-print mr-2"></i> Print Ticket</button>
                    <button class="btn-outline"><i class="fas fa-envelope mr-2"></i> Email Ticket</button>
                    <a href="/dashboard" class="btn-outline ml-auto"><i class="fas fa-home mr-2"></i> Go to Dashboard</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
