<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RITCO - Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <style>
        * { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Poppins', sans-serif; }
        
        .login-page {
            display: flex;
            min-height: 100vh;
        }
        
        /* Left Side - Login Form */
        .login-left {
            width: 45%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
            background: white;
            position: relative;
        }
        
        .login-form-container {
            max-width: 380px;
            width: 100%;
        }
        
        .brand-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 32px;
        }
        .brand-header .logo {
            width: 44px;
            height: 44px;
            background: #15803D;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .brand-header .logo i {
            color: white;
            font-size: 20px;
        }
        .brand-header h1 {
            font-size: 24px;
            font-weight: 800;
            color: #111827;
        }
        .brand-header .badge {
            background: #DCFCE7;
            color: #15803D;
            font-size: 10px;
            font-weight: 600;
            padding: 2px 10px;
            border-radius: 20px;
            text-transform: uppercase;
            margin-left: -4px;
        }
        
        .login-title {
            font-size: 28px;
            font-weight: 700;
            color: #111827;
            margin-bottom: 8px;
        }
        .login-subtitle {
            color: #6B7280;
            font-size: 15px;
            margin-bottom: 28px;
        }
        
        .input-field {
            width: 100%;
            padding: 12px 16px;
            border: 1.5px solid #E5E7EB;
            border-radius: 10px;
            font-size: 14px;
            transition: all 0.2s;
            background: #F9FAFB;
        }
        .input-field:focus {
            outline: none;
            border-color: #15803D;
            background: white;
            box-shadow: 0 0 0 3px rgba(21, 128, 61, 0.08);
        }
        .input-field::placeholder {
            color: #9CA3AF;
        }
        
        .btn-login {
            background: #15803D;
            color: white;
            padding: 13px;
            border-radius: 10px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            width: 100%;
            transition: all 0.2s;
            font-size: 15px;
        }
        .btn-login:hover {
            background: #166534;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(21, 128, 61, 0.3);
        }
        .btn-login:active {
            transform: translateY(0);
        }
        
        .form-options {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin: 16px 0 20px;
        }
        .form-options label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            color: #6B7280;
            cursor: pointer;
        }
        .form-options label input[type="checkbox"] {
            width: 16px;
            height: 16px;
            accent-color: #15803D;
            border-radius: 4px;
        }
        .form-options a {
            font-size: 14px;
            color: #15803D;
            font-weight: 500;
            text-decoration: none;
            transition: color 0.2s;
        }
        .form-options a:hover {
            color: #166534;
            text-decoration: underline;
        }
        
        .register-link {
            text-align: center;
            margin-top: 20px;
            font-size: 14px;
            color: #6B7280;
        }
        .register-link a {
            color: #15803D;
            font-weight: 600;
            text-decoration: none;
            transition: color 0.2s;
        }
        .register-link a:hover {
            color: #166534;
            text-decoration: underline;
        }
        
        .alert-success {
            background: #DCFCE7;
            color: #15803D;
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 14px;
            margin-top: 12px;
        }
        .alert-error {
            background: #FEE2E2;
            color: #DC2626;
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 14px;
            margin-top: 12px;
        }
        
        /* Right Side - Image Background */
        .login-right {
            width: 55%;
            background-image: url('/images/login-bg.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            position: relative;
        }
        .login-right::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(21, 128, 61, 0.15);
        }
        .login-right-content {
            position: relative;
            z-index: 2;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 60px;
            color: white;
        }
        .login-right-content h2 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 12px;
            text-shadow: 0 2px 8px rgba(0,0,0,0.2);
        }
        .login-right-content p {
            font-size: 16px;
            opacity: 0.9;
            max-width: 400px;
            text-shadow: 0 2px 4px rgba(0,0,0,0.2);
        }
        .login-right-content .features {
            margin-top: 24px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .login-right-content .features span {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            opacity: 0.9;
        }
        .login-right-content .features i {
            color: #22C55E;
            font-size: 18px;
        }
        
        /* Responsive */
        @media (max-width: 1024px) {
            .login-left { width: 50%; padding: 30px; }
            .login-right { width: 50%; }
        }
        
        @media (max-width: 768px) {
            .login-page { flex-direction: column; }
            .login-left { width: 100%; padding: 24px; min-height: 100vh; }
            .login-right { display: none; }
            .login-form-container { max-width: 100%; }
            .login-title { font-size: 24px; }
        }
    </style>
</head>
<body>
    <div class="login-page">
        <!-- Left Side - Login Form -->
        <div class="login-left">
            <div class="login-form-container">
                <!-- Brand -->
                <div class="brand-header">
                    <div class="logo">
                        <i class="fas fa-bus"></i>
                    </div>
                    <h1>RITCO</h1>
                    <span class="badge">Official</span>
                </div>

                <h2 class="login-title">Welcome Back</h2>
                <p class="login-subtitle">Sign in to access your account</p>

                <form id="loginForm">
                    <div style="margin-bottom: 16px;">
                        <input type="email" id="email" placeholder="Email address" class="input-field"/>
                    </div>
                    <div style="margin-bottom: 16px;">
                        <input type="password" id="password" placeholder="Password" class="input-field"/>
                    </div>

                    <div class="form-options">
                        <label>
                            <input type="checkbox"/> Remember me
                        </label>
                        <a href="#">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn-login">
                        <i class="fas fa-sign-in-alt mr-2"></i> Sign In
                    </button>
                </form>

                <div id="loginMessage"></div>

                <div class="register-link">
                    Don't have an account? <a href="/register">Create Account</a>
                </div>
            </div>
        </div>

        <!-- Right Side - Image Background -->
        <div class="login-right">
            <div class="login-right-content">
                <h2>Travel Across Rwanda</h2>
                <p>Comfortable, safe, and reliable bus transport across the country.</p>
                <div class="features">
                    <span><i class="fas fa-check-circle"></i> Book tickets instantly</span>
                    <span><i class="fas fa-check-circle"></i> Track your bus in real-time</span>
                    <span><i class="fas fa-check-circle"></i> 24/7 customer support</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const msg = document.getElementById('loginMessage');
            
            msg.innerHTML = '<div class="alert-success">⏳ Logging in...</div>';
            
            try {
                const response = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });
                const result = await response.json();
                
                if (result.success) {
                    const role = result.user.role || 'user';
                    const redirectUrl = result.redirect || (role === 'admin' ? '/admin' : '/dashboard');
                    
                    msg.innerHTML = `<div class="alert-success">✅ Login successful! Redirecting...</div>`;
                    
                    setTimeout(() => { 
                        window.location.href = redirectUrl; 
                    }, 1200);
                } else {
                    msg.innerHTML = `<div class="alert-error">❌ ${result.error || 'Invalid credentials'}</div>`;
                }
            } catch (error) {
                msg.innerHTML = '<div class="alert-error">❌ Network error. Please try again.</div>';
            }
        });
    </script>
</body>
</html>
