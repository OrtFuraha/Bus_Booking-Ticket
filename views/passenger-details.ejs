<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RITCO - Passenger Details</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <style>
        * { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Poppins', sans-serif; }
        .input-field { width: 100%; padding: 12px 16px; border: 1px solid #E5E7EB; border-radius: 10px; font-size: 15px; transition: border 0.2s; background: white; }
        .input-field:focus { outline: none; border-color: #15803D; box-shadow: 0 0 0 3px rgba(21, 128, 61, 0.1); }
        .btn-primary { background: #15803D; color: white; padding: 12px 32px; border-radius: 10px; font-weight: 600; border: none; cursor: pointer; transition: background 0.2s; }
        .btn-primary:hover { background: #166534; }
        .btn-outline { background: transparent; color: #15803D; padding: 12px 32px; border-radius: 10px; font-weight: 600; border: 2px solid #15803D; cursor: pointer; transition: all 0.2s; }
        .btn-outline:hover { background: #15803D; color: white; }
        .nav-link { color: #1F2937; font-weight: 500; padding: 8px 16px; border-radius: 8px; transition: background 0.2s; }
        .nav-link:hover { background: #F3F4F6; }
        .card { background: white; border-radius: 10px; padding: 24px; border: 1px solid #E5E7EB; }
    </style>
</head>
<body>
    <div class="min-h-screen bg-[#F8FAFC]">
        <!-- Top Nav -->
        <nav class="bg-white border-b border-gray-200">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between items-center h-16">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-[#15803D] rounded-lg flex items-center justify-center"><i class="fas fa-bus text-white text-xl"></i></div>
                        <span class="text-2xl font-bold text-[#111827]">RITCO</span>
                    </div>
                    <div class="flex items-center space-x-4">
                        <span class="text-sm text-[#6B7280]"><i class="fas fa-user text-[#15803D] mr-1"></i> John Doe</span>
                    </div>
                </div>
            </div>
        </nav>

        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h1 class="text-2xl font-bold text-[#111827]">Passenger Details</h1>
                    <p class="text-[#6B7280] text-sm">Enter passenger information for your booking</p>
                </div>
                <span class="text-sm font-semibold text-[#15803D] bg-[#DCFCE7] px-4 py-2 rounded-full">Step 2 of 4</span>
            </div>

            <div class="card">
                <form class="space-y-4">
                    <div class="grid md:grid-cols-2 gap-4">
                        <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Passenger Name</label><input type="text" placeholder="Full name" class="input-field"/></div>
                        <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Age</label><input type="number" placeholder="Age" class="input-field"/></div>
                        <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Gender</label><select class="input-field"><option>Male</option><option>Female</option></select></div>
                        <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Phone</label><input type="tel" placeholder="+250 78 000 0000" class="input-field"/></div>
                        <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Email</label><input type="email" placeholder="you@email.com" class="input-field"/></div>
                        <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Emergency Contact</label><input type="tel" placeholder="+250 78 000 0000" class="input-field"/></div>
                    </div>
                    <div><label class="block text-sm font-medium text-[#6B7280] mb-1">Special Requests</label><textarea rows="3" placeholder="Any special requirements..." class="input-field"></textarea></div>

                    <div class="flex flex-wrap gap-4 pt-4 border-t border-gray-200">
                        <a href="/seat-selection" class="btn-outline"><i class="fas fa-arrow-left mr-2"></i> Back</a>
                        <a href="/payment" class="btn-primary ml-auto"><i class="fas fa-arrow-right mr-2"></i> Continue to Payment</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
