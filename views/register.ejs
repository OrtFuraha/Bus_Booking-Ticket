<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RITCO - Register</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <style>
        * { font-family: 'Inter', sans-serif; }
        h1, h2 { font-family: 'Poppins', sans-serif; }
        .register-card { background: white; border-radius: 12px; padding: 40px; border: 1px solid #E5E7EB; box-shadow: 0 4px 20px rgba(0,0,0,0.05); max-width: 500px; width: 100%; }
        .input-field { width: 100%; padding: 12px 16px; border: 1px solid #E5E7EB; border-radius: 10px; font-size: 15px; transition: border 0.2s; background: white; }
        .input-field:focus { outline: none; border-color: #15803D; box-shadow: 0 0 0 3px rgba(21, 128, 61, 0.1); }
        .btn-register { background: #15803D; color: white; padding: 12px; border-radius: 10px; font-weight: 600; border: none; cursor: pointer; width: 100%; transition: background 0.2s; }
        .btn-register:hover { background: #166534; }
        .register-bg { background: #F8FAFC; }
    </style>
</head>
<body>
    <div class="min-h-screen register-bg flex items-center justify-center p-4">
        <div class="register-card">
            <div class="flex items-center space-x-3 mb-6">
                <div class="w-10 h-10 bg-[#15803D] rounded-lg flex items-center justify-center">
                    <i class="fas fa-bus text-white text-lg"></i>
                </div>
                <span class="text-2xl font-bold text-[#111827]">RITCO</span>
            </div>
            <h2 class="text-2xl font-bold text-[#111827] mb-2">Create Account</h2>
            <p class="text-[#6B7280] mb-6">Join RITCO and start booking your bus tickets</p>
            <form id="registerForm" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-[#6B7280] mb-1"><i class="fas fa-user text-[#15803D] mr-1"></i> Full Name</label>
                    <input type="text" id="name" placeholder="John Doe" class="input-field"/>
                </div>
                <div>
                    <label class="block text-sm font-medium text-[#6B7280] mb-1"><i class="fas fa-id-card text-[#15803D] mr-1"></i> National ID</label>
                    <input type="text" id="nationalId" placeholder="1234567890123456" class="input-field"/>
                </div>
                <div>
                    <label class="block text-sm font-medium text-[#6B7280] mb-1"><i class="fas fa-phone text-[#15803D] mr-1"></i> Phone</label>
                    <input type="tel" id="phone" placeholder="+250 78 000 0000" class="input-field"/>
                </div>
                <div>
                    <label class="block text-sm font-medium text-[#6B7280] mb-1"><i class="fas fa-envelope text-[#15803D] mr-1"></i> Email</label>
                    <input type="email" id="email" placeholder="you@email.com" class="input-field"/>
                </div>
                <div>
                    <label class="block text-sm font-medium text-[#6B7280] mb-1"><i class="fas fa-lock text-[#15803D] mr-1"></i> Password</label>
                    <input type="password" id="password" placeholder="Create a strong password" class="input-field"/>
                </div>
                <div>
                    <label class="block text-sm font-medium text-[#6B7280] mb-1"><i class="fas fa-check-circle text-[#15803D] mr-1"></i> Confirm Password</label>
                    <input type="password" id="confirmPassword" placeholder="Confirm your password" class="input-field"/>
                </div>
                <div class="flex items-start space-x-2">
                    <input type="checkbox" id="terms" class="w-4 h-4 mt-1 text-[#15803D] border-gray-300 rounded"/>
                    <label class="text-sm text-[#6B7280]">I agree to the <a href="#" class="text-[#15803D] font-semibold hover:underline">Terms & Conditions</a></label>
                </div>
                <button type="submit" class="btn-register"><i class="fas fa-user-plus mr-2"></i> Create Account</button>
            </form>
            <div id="registerMessage" style="margin-top: 15px;"></div>
            <p class="text-center text-[#6B7280] text-sm mt-6">Already have an account? <a href="/login" class="text-[#15803D] font-semibold hover:underline">Sign In</a></p>
        </div>
    </div>
    <script>
        document.getElementById('registerForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const msg = document.getElementById('registerMessage');
            msg.innerHTML = '<div style="background:#DCFCE7;color:#15803D;padding:12px;border-radius:8px;">Account created successfully! Redirecting...</div>';
            setTimeout(() => { window.location.href = '/login'; }, 1500);
        });
    </script>
</body>
</html>
