<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RITCO - Seat Selection</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <style>
        * { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Poppins', sans-serif; }
        .seat { width: 40px; height: 40px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 12px; cursor: pointer; transition: all 0.2s; border: 2px solid #E5E7EB; }
        .seat:hover { transform: scale(1.05); }
        .seat-available { background: #DCFCE7; border-color: #15803D; color: #15803D; }
        .seat-available:hover { background: #15803D; color: white; }
        .seat-selected { background: #15803D; border-color: #15803D; color: white; }
        .seat-booked { background: #F3F4F6; border-color: #D1D5DB; color: #9CA3AF; cursor: not-allowed; }
        .seat-reserved { background: #FEF3C7; border-color: #F59E0B; color: #D97706; }
        .seat-female { background: #DBEAFE; border-color: #2563EB; color: #2563EB; }
        .bus-layout { background: white; border-radius: 10px; padding: 24px; border: 1px solid #E5E7EB; }
        .driver-seat { background: #111827; color: white; padding: 8px 16px; border-radius: 8px; text-align: center; font-size: 14px; }
        .legend-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #6B7280; }
        .btn-primary { background: #15803D; color: white; padding: 12px 32px; border-radius: 10px; font-weight: 600; border: none; cursor: pointer; transition: background 0.2s; }
        .btn-primary:hover { background: #166534; }
        .btn-outline { background: transparent; color: #15803D; padding: 12px 32px; border-radius: 10px; font-weight: 600; border: 2px solid #15803D; cursor: pointer; transition: all 0.2s; }
        .btn-outline:hover { background: #15803D; color: white; }
        .nav-link { color: #1F2937; font-weight: 500; padding: 8px 16px; border-radius: 8px; transition: background 0.2s; }
        .nav-link:hover { background: #F3F4F6; }
    </style>
</head>
<body>
    <div class="min-h-screen bg-[#F8FAFC]">
        <!-- Top Nav -->
        <nav class="bg-white border-b border-gray-200">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between items-center h-16">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-[#15803D] rounded-lg flex items-center justify-center"><i class="fas fa-bus text-white text-xl"></i></div>
                        <span class="text-2xl font-bold text-[#111827]">RITCO</span>
                    </div>
                    <div class="flex items-center space-x-4">
                        <span class="text-sm text-[#6B7280]"><i class="fas fa-user text-[#15803D] mr-1"></i> John Doe</span>
                    </div>
                </div>
            </div>
        </nav>

        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h1 class="text-2xl font-bold text-[#111827]">Select Your Seats</h1>
                    <p class="text-[#6B7280] text-sm">Kigali → Musanze • Dec 10, 2024 • 8:30 AM</p>
                </div>
                <div class="text-right">
                    <p class="text-sm text-[#6B7280]">Bus</p>
                    <p class="font-bold text-[#111827]">Volcano Express</p>
                </div>
            </div>

            <!-- Seat Layout -->
            <div class="bus-layout">
                <!-- Driver -->
                <div class="driver-seat mb-6">
                    <i class="fas fa-user text-white mr-2"></i> Driver
                </div>

                <!-- Seats Grid -->
                <div class="grid grid-cols-4 gap-3 max-w-md mx-auto">
                    <!-- Row 1 -->
                    <div class="seat seat-available">1</div>
                    <div class="seat seat-available">2</div>
                    <div class="seat seat-available">3</div>
                    <div class="seat seat-available">4</div>
                    <!-- Row 2 -->
                    <div class="seat seat-booked">5</div>
                    <div class="seat seat-available">6</div>
                    <div class="seat seat-available">7</div>
                    <div class="seat seat-booked">8</div>
                    <!-- Row 3 -->
                    <div class="seat seat-available">9</div>
                    <div class="seat seat-selected">10</div>
                    <div class="seat seat-selected">11</div>
                    <div class="seat seat-available">12</div>
                    <!-- Row 4 -->
                    <div class="seat seat-reserved">13</div>
                    <div class="seat seat-available">14</div>
                    <div class="seat seat-available">15</div>
                    <div class="seat seat-available">16</div>
                    <!-- Row 5 -->
                    <div class="seat seat-female">17</div>
                    <div class="seat seat-female">18</div>
                    <div class="seat seat-available">19</div>
                    <div class="seat seat-available">20</div>
                </div>

                <!-- Legend -->
                <div class="flex flex-wrap gap-4 mt-6 pt-6 border-t border-gray-200">
                    <div class="legend-item"><div class="seat seat-available" style="width:24px;height:24px;"></div> Available</div>
                    <div class="legend-item"><div class="seat seat-selected" style="width:24px;height:24px;"></div> Selected</div>
                    <div class="legend-item"><div class="seat seat-booked" style="width:24px;height:24px;"></div> Booked</div>
                    <div class="legend-item"><div class="seat seat-reserved" style="width:24px;height:24px;"></div> Reserved</div>
                    <div class="legend-item"><div class="seat seat-female" style="width:24px;height:24px;"></div> Female Only</div>
                </div>
            </div>

            <!-- Trip Summary -->
            <div class="bg-white rounded-xl border border-gray-200 p-6 mt-6">
                <div class="grid md:grid-cols-4 gap-4">
                    <div><span class="text-[#6B7280] text-sm">Route</span><p class="font-bold text-[#111827]">Kigali → Musanze</p></div>
                    <div><span class="text-[#6B7280] text-sm">Date & Time</span><p class="font-bold text-[#111827]">Dec 10, 8:30 AM</p></div>
                    <div><span class="text-[#6B7280] text-sm">Seats Selected</span><p class="font-bold text-[#111827]">2 (10, 11)</p></div>
                    <div><span class="text-[#6B7280] text-sm">Total Price</span><p class="font-bold text-[#15803D] text-xl">6,000 RWF</p></div>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex flex-wrap gap-4 mt-6">
                <a href="/search" class="btn-outline"><i class="fas fa-arrow-left mr-2"></i> Back</a>
                <a href="/passenger-details" class="btn-primary ml-auto"><i class="fas fa-arrow-right mr-2"></i> Continue</a>
            </div>
        </div>
    </div>
</body>
</html>
